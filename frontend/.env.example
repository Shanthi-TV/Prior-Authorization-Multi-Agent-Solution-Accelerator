# =============================================================================
# Prior Authorization Review — Frontend Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Variables WITHOUT the VITE_ prefix are available only in vite.config.ts
# (Node.js context) and are NOT shipped to the browser.
# =============================================================================

# ---------------------------------------------------------------------------
# API base path (browser-side, available at runtime)
# ---------------------------------------------------------------------------
# Base URL path for API calls. In development, Vite proxies /api to the
# backend. In production/container builds, set to the full backend URL
# (e.g., https://api.example.com/api).
VITE_API_BASE=/api

# ---------------------------------------------------------------------------
# Dev server settings (Node-side, vite.config.ts only)
# ---------------------------------------------------------------------------
# Port for the Vite dev server
VITE_DEV_PORT=5173

# Backend URL that the Vite dev proxy forwards /api requests to
VITE_API_PROXY_TARGET=http://localhost:8000
